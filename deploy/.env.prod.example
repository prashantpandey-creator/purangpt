# PuranGPT production stack env — TEMPLATE.
# Copy to /root/stack.env on the server and fill with REAL values, then:
#   docker compose --env-file /root/stack.env -f deploy/docker-compose.prod.yml up -d
# NEVER commit the filled-in version (the real /root/stack.env is gitignored).

# ── Frontend public build args (baked into the client bundle) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_REVENUECAT_APPLE_KEY=your_revenuecat_public_sdk_key

# ── Frontend runtime ─────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key
DATABASE_URL=postgresql://logto:logto@logto-db:5432/logto
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
GITHUB_PAT=ghp_xxx

# ── Logto (auth) ─────────────────────────────────────────────────────────────
LOGTO_DB_URL=postgresql://logto:logto@logto-db:5432/logto
LOGTO_DB_USER=logto
LOGTO_DB_PASSWORD=logto
LOGTO_DB_NAME=logto

# NOTE: Backend secrets (VECTOR_DB_URL, DEEPSEEK_API_KEY, …) live in
# /root/purangpt/.env (the backend's own env_file), NOT here.
# Frontend auth secrets (LOGTO_*, GOOGLE_*, cookie) live in
# /root/frontend-secrets.env. See purangpt-next/CLAUDE-secrets.md.
