# PuranGPT production stack env — TEMPLATE.
# !! PREFERRED WORKFLOW: use secrets/sync-to-server.sh (SOPS + age) instead of
#    maintaining this file manually. This template documents what keys exist.
#
# If syncing manually: copy to /root/stack.env on the server and fill values:
#   docker compose --env-file /root/stack.env -f deploy/docker-compose.prod.yml up -d
# NEVER commit the filled-in version (the real /root/stack.env is gitignored).

# ── Frontend public build args (baked into the client bundle) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # legacy, can be removed
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key        # legacy, can be removed
NEXT_PUBLIC_REVENUECAT_APPLE_KEY=appl_xxx                   # RevenueCat iOS public SDK key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx                    # Razorpay public key (safe to expose)

# ── Frontend runtime ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxx
DATABASE_URL=postgresql://logto:logto@logto-db:5432/logto
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
GITHUB_PAT=ghp_xxx

# ── Logto (auth) ─────────────────────────────────────────────────────────────
LOGTO_DB_URL=postgresql://logto:logto@logto-db:5432/logto
LOGTO_DB_USER=logto
LOGTO_DB_PASSWORD=logto
LOGTO_DB_NAME=logto

# NOTE: Backend secrets (VECTOR_DB_URL, LLM keys, …) live in /root/purangpt/.env.
# Frontend auth secrets (LOGTO_*, GOOGLE_*, cookie) live in /root/frontend-secrets.env.
# Both files are rendered from secrets/prod.enc.yaml via secrets/sync-to-server.sh.
