# ── PuranGPT Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────────────────
# "auto"   = Try Ollama first, fall back to Groq
# "ollama" = Always use local Ollama
# "groq"   = Always use Groq API
LLM_PROVIDER=auto

# ── Ollama (Local LLM) ───────────────────────────────────────────────────
# Install: https://ollama.ai
# Pull model: ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Groq API (Cloud LLM — faster, free tier available) ───────────────────
# Get free key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# ── Gemini API (Cloud LLM) ───────────────────────────────────────────────
# Get free key: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Data Directories ─────────────────────────────────────────────────────
DATA_DIR=./data
DB_DIR=./data/chroma_db
CHUNKS_DIR=./data/chunks
INDEX_DIR=./data/indexes

# ── Embedding Model ───────────────────────────────────────────────────────
# Large (best quality, ~2GB): intfloat/multilingual-e5-large
# Small (fast, ~500MB):       intfloat/multilingual-e5-small
EMBED_MODEL=intfloat/multilingual-e5-large

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
