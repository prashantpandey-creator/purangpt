# ── PuranGPT Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────────────────
# "auto"   = Default to DeepSeek, optionally Ollama if configured
# "ollama" = Always use local Ollama
# "deepseek" = Always use DeepSeek
LLM_PROVIDER=auto

# ── Ollama (Local LLM) ───────────────────────────────────────────────────
# Install: https://ollama.ai
# Pull model: ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── DeepSeek API (Cloud LLM — primary production engine) ───────────────
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# ── Vector / App Database (pgvector on Postgres) ─────────────────────────
# REQUIRED for hybrid search (HybridSearcher) AND profiles/billing/usage.
# Without it the searcher falls back to a localhost default that doesn't exist
# in the container, so /api/status shows index_ready:false. In production this
# is the Logto Postgres; in Docker use the service hostname (logto-db):
#   VECTOR_DB_URL=postgresql://logto:logto@logto-db:5432/logto
VECTOR_DB_URL=postgresql://logto:logto@localhost:5432/logto

# ── Data Directories ─────────────────────────────────────────────────────
DATA_DIR=./data
DB_DIR=./data/chroma_db
CHUNKS_DIR=./data/chunks
INDEX_DIR=./data/indexes

# ── Embedding Model ───────────────────────────────────────────────────────
# Large (best quality, ~2GB): intfloat/multilingual-e5-large
# Small (fast, ~500MB):       intfloat/multilingual-e5-small
EMBED_MODEL=intfloat/multilingual-e5-large

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
